# AICreator environment variables
# Copy to .env and adjust values as needed.

# Database connection (required for PostgreSQL; default: sqlite:///./aicreator.db)
AICREATOR_DATABASE_URL=postgresql://aicreator:aicreator@localhost:5432/aicreator

# Logging
AICREATOR_LOG_LEVEL=INFO
AICREATOR_LOG_FORMAT=text  # "text" or "json"

# API server
AICREATOR_API_HOST=0.0.0.0
AICREATOR_API_PORT=8000
